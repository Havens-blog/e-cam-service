# ARMS APM 推送脚本配置
# 复制为 .env 并填入真实值

# ARMS API 凭证（base64 编码）
# 编码命令：echo -n "your-value" | base64
ARMS_ACCESS_KEY_ID=
ARMS_ACCESS_KEY_SECRET=
ARMS_REGION_ID=cn-shenzhen

# 拓扑声明端点地址
TOPOLOGY_API_URL=http://localhost:8001/api/v1/cam/topology/declarations

# K8s 集群标识
K8S_CLUSTER_NAME=default

# 租户 ID
TENANT_ID=
