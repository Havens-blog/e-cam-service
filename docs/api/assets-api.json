{
  "openapi": "3.0.0",
  "info": {
    "title": "云资产管理 API",
    "description": "统一的云资产（ECS、RDS、Redis、MongoDB、VPC、EIP）查询接口，从本地数据库读取已同步的资产数据",
    "version": "2.1.0",
    "contact": {
      "name": "E-CAM Service",
      "email": "support@example.com"
    }
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API Base URL"
    }
  ],
  "tags": [
    {
      "name": "ECS",
      "description": "云虚拟机管理"
    },
    {
      "name": "RDS",
      "description": "云数据库 MySQL/PostgreSQL 管理"
    },
    {
      "name": "Redis",
      "description": "云 Redis 缓存管理"
    },
    {
      "name": "MongoDB",
      "description": "云 MongoDB 数据库管理"
    },
    {
      "name": "VPC",
      "description": "虚拟私有云管理"
    },
    {
      "name": "EIP",
      "description": "弹性公网IP管理"
    }
  ],
  "paths": {
    "/cam/assets/ecs": {
      "get": {
        "tags": ["ECS"],
        "summary": "获取ECS实例列表",
        "description": "从数据库获取已同步的云虚拟机实例列表",
        "operationId": "listECSInstances",
        "parameters": [
          {
            "$ref": "#/components/parameters/TenantId"
          },
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/Provider"
          },
          {
            "$ref": "#/components/parameters/Region"
          },
          {
            "$ref": "#/components/parameters/Status"
          },
          {
            "$ref": "#/components/parameters/Name"
          },
          {
            "$ref": "#/components/parameters/Offset"
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetListResponse"
                },
                "example": {
                  "code": 0,
                  "msg": "success",
                  "data": {
                    "items": [
                      {
                        "id": 1,
                        "asset_id": "i-bp1xxxxx",
                        "asset_name": "web-server-01",
                        "asset_type": "ecs",
                        "tenant_id": "tenant-001",
                        "account_id": 1,
                        "provider": "aliyun",
                        "region": "cn-hangzhou",
                        "status": "running",
                        "attributes": {
                          "cpu": 4,
                          "memory": 8192,
                          "os_type": "linux",
                          "instance_type": "ecs.c6.xlarge"
                        },
                        "create_time": 1706000000000,
                        "update_time": 1706000000000
                      }
                    ],
                    "total": 100
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
