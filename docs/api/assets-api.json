  "components": {
    "parameters": {
      "TenantId": {
        "name": "tenant_id",
        "in": "query",
        "required": false,
        "description": "租户ID",
        "schema": {
          "type": "string",
          "example": "tenant-001"
        }
      },
      "AccountId": {
        "name": "account_id",
        "in": "query",
        "required": false,
        "description": "云账号ID",
        "schema": {
          "type": "integer",
          "example": 1
        }
      },
      "Provider": {
        "name": "provider",
        "in": "query",
        "required": false,
        "description": "云厂商",
        "schema": {
          "type": "string",
          "enum": ["aliyun", "aws", "huawei", "tencent", "volcano"],
          "example": "aliyun"
        }
      },
      "Region": {
        "name": "region",
        "in": "query",
        "required": false,
        "description": "地域",
        "schema": {
          "type": "string",
          "example": "cn-hangzhou"
        }
      },
      "Status": {
        "name": "status",
        "in": "query",
        "required": false,
        "description": "实例状态",
        "schema": {
          "type": "string",
          "example": "running"
        }
      },
      "Name": {
        "name": "name",
        "in": "query",
        "required": false,
        "description": "实例名称（模糊搜索）",
        "schema": {
          "type": "string",
          "example": "web-server"
        }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "required": false,
        "description": "偏移量",
        "schema": {
          "type": "integer",
          "default": 0,
          "example": 0
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "限制数量",
        "schema": {
          "type": "integer",
          "default": 20,
          "example": 20
        }
      },
      "AssetIdPath": {
        "name": "asset_id",
        "in": "path",
        "required": true,
        "description": "资产ID（云厂商实例ID）",
        "schema": {
          "type": "string",
          "example": "i-bp1xxxxx"
        }
      }
    },
    "schemas": {
      "Asset": {
        "type": "object",
        "description": "统一资产对象",
        "properties": {
          "id": {
            "type": "integer",
            "description": "数据库ID",
            "example": 1
          },
          "asset_id": {
            "type": "string",
            "description": "云厂商实例ID",
            "example": "i-bp1xxxxx"
          },
          "asset_name": {
            "type": "string",
            "description": "实例名称",
            "example": "web-server-01"
          },
          "asset_type": {
            "type": "string",
            "description": "资产类型",
            "enum": ["ecs", "rds", "redis", "mongodb", "vpc", "eip"],
            "example": "ecs"
          },
          "tenant_id": {
            "type": "string",
            "description": "租户ID",
            "example": "tenant-001"
          },
          "account_id": {
            "type": "integer",
            "description": "云账号ID",
            "example": 1
          },
          "provider": {
            "type": "string",
            "description": "云厂商",
            "enum": ["aliyun", "aws", "huawei", "tencent", "volcano"],
            "example": "aliyun"
          },
          "region": {
            "type": "string",
            "description": "地域",
            "example": "cn-hangzhou"
          },
          "status": {
            "type": "string",
            "description": "实例状态",
            "example": "running"
          },
          "attributes": {
            "type": "object",
            "description": "扩展属性（不同资产类型有不同字段）",
            "additionalProperties": true
          },
          "create_time": {
            "type": "integer",
            "description": "创建时间（毫秒时间戳）",
            "example": 1706000000000
          },
          "update_time": {
            "type": "integer",
            "description": "更新时间（毫秒时间戳）",
            "example": 1706000000000
          }
        }
      },
      "AssetListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0表示成功",
            "example": 0
          },
          "msg": {
            "type": "string",
            "description": "状态消息",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Asset"
                }
              },
              "total": {
                "type": "integer",
                "description": "总数",
                "example": 100
              }
            }
          }
        }
      },
