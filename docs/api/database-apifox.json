          },
          {
            "name": "region",
            "in": "query",
            "required": true,
            "description": "地域",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RedisInstanceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cam/databases/mongodb": {
      "get": {
        "tags": ["MongoDB"],
        "summary": "获取MongoDB实例列表",
