              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MongoDBInstanceResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，0表示成功",
            "example": 0
          },
          "msg": {
            "type": "string",
            "description": "状态消息",
            "example": "success"
          },
          "data": {
            "type": "object",
            "description": "响应数据"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 400
          },
          "msg": {
            "type": "string",
            "example": "请求参数错误"
          }
        }
      },
      "RDSInstance": {
        "type": "object",
        "properties": {
          "instance_id": {
            "type": "string",
            "description": "实例ID",
            "example": "rm-bp1xxxxx"
          },
          "instance_name": {
            "type": "string",
            "description": "实例名称",
            "example": "prod-mysql-01"
          },
          "engine": {
            "type": "string",
            "description": "数据库引擎",
            "example": "mysql"
          },
          "engine_version": {
            "type": "string",
            "description": "引擎版本",
            "example": "8.0"
          },
          "instance_class": {
            "type": "string",
            "description": "实例规格",
            "example": "rds.mysql.s2.large"
          },
          "instance_status": {
            "type": "string",
            "description": "实例状态",
            "example": "running"
          },
          "connection_string": {
            "type": "string",
            "description": "连接地址",
            "example": "rm-bp1xxxxx.mysql.rds.aliyuncs.com"
          },
          "port": {
            "type": "integer",
            "description": "端口",
            "example": 3306
          },
          "vpc_id": {
            "type": "string",
            "description": "VPC ID"
          },
          "vswitch_id": {
            "type": "string",
            "description": "交换机ID"
          },
          "zone_id": {
            "type": "string",
            "description": "可用区ID"
          },
          "region_id": {
            "type": "string",
            "description": "地域ID"
          },
          "storage_type": {
            "type": "string",
            "description": "存储类型"
          },
          "storage_size": {
            "type": "integer",
            "description": "存储大小(GB)"
          },
          "max_connections": {
            "type": "integer",
            "description": "最大连接数"
          },
          "max_iops": {
            "type": "integer",
            "description": "最大IOPS"
          },
          "create_time": {
            "type": "string",
            "description": "创建时间"
          },
          "expire_time": {
            "type": "string",
            "description": "过期时间"
          },
          "pay_type": {
            "type": "string",
            "description": "付费类型"
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "标签"
          }
        }
      },
      "RDSInstanceListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "msg": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "instances": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RDSInstance"
                }
              },
              "total": {
                "type": "integer",
                "description": "总数"
              }
            }
          }
        }
      },
      "RDSInstanceResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "msg": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/RDSInstance"
          }
        }
      },
      "RedisInstance": {
        "type": "object",
        "properties": {
          "instance_id": {
            "type": "string",
            "description": "实例ID",
            "example": "r-bp1xxxxx"
          },
          "instance_name": {
            "type": "string",
            "description": "实例名称"
          },
          "instance_class": {
            "type": "string",
            "description": "实例规格"
          },
          "instance_status": {
            "type": "string",
            "description": "实例状态"
          },
          "engine_version": {
            "type": "string",
            "description": "引擎版本"
          },
          "architecture": {
            "type": "string",
            "description": "架构类型"
          },
          "node_type": {
            "type": "string",
            "description": "节点类型"
          },
          "shard_count": {
            "type": "integer",
            "description": "分片数"
          },
          "connection_domain": {
            "type": "string",
            "description": "连接地址"
          },
          "port": {
            "type": "integer",
            "description": "端口"
          },
          "vpc_id": {
            "type": "string"
          },
          "vswitch_id": {
            "type": "string"
          },
          "zone_id": {
            "type": "string"
          },
          "region_id": {
            "type": "string"
          },
          "capacity": {
            "type": "integer",
            "description": "容量(MB)"
