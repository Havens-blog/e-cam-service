        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "description": "云账号ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": true,
            "description": "地域",
            "schema": {
              "type": "string",
              "example": "cn-hangzhou"
            }
          },
          {
            "name": "architecture",
            "in": "query",
            "required": false,
            "description": "架构类型",
            "schema": {
              "type": "string",
              "enum": ["standard", "cluster", "rwsplit"]
            }
          },
          {
            "name": "status",
            "in": "query",
