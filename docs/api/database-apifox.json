              }
            }
          }
        }
      }
    },
    "/cam/databases/redis/{instance_id}": {
      "get": {
        "tags": ["Redis"],
        "summary": "获取Redis实例详情",
        "description": "获取指定Redis实例的详细信息",
        "operationId": "getRedisInstance",
        "parameters": [
          {
            "name": "instance_id",
            "in": "path",
            "required": true,
            "description": "Redis实例ID",
            "schema": {
              "type": "string",
              "example": "r-bp1xxxxx"
            }
          },
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "description": "云账号ID",
            "schema": {
              "type": "integer"
