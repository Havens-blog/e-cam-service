                  "$ref": "#/components/schemas/MongoDBInstance"
                }
              },
              "total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "MongoDBInstanceResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
