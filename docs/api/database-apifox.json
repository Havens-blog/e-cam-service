          "bandwidth": {
            "type": "integer",
            "description": "带宽(Mbps)"
          },
          "connections": {
            "type": "integer",
            "description": "最大连接数"
          },
          "qps": {
            "type": "integer",
            "description": "QPS"
          },
          "create_time": {
            "type": "string"
          },
          "expire_time": {
            "type": "string"
          },
          "pay_type": {
            "type": "string"
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "RedisInstanceListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "msg": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "instances": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RedisInstance"
                }
              },
              "total": {
                "type": "integer"
              }
            }
          }
        }
      },
      "RedisInstanceResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
