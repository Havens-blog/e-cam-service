    "/cam/databases/mongodb/{instance_id}": {
      "get": {
        "tags": ["MongoDB"],
        "summary": "获取MongoDB实例详情",
        "description": "获取指定MongoDB实例的详细信息",
        "operationId": "getMongoDBInstance",
        "parameters": [
          {
            "name": "instance_id",
            "in": "path",
            "required": true,
            "description": "MongoDB实例ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "description": "云账号ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": true,
            "description": "地域",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
