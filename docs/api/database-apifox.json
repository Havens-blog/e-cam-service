{
  "openapi": "3.0.0",
  "info": {
    "title": "数据库资源管理 API",
    "description": "云数据库资源（RDS、Redis、MongoDB）管理接口",
    "version": "1.0.0",
    "contact": {
      "name": "E-CAM Service",
      "email": "support@example.com"
    }
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API Base URL"
    }
  ],
  "tags": [
    {
      "name": "RDS",
      "description": "云数据库 MySQL/PostgreSQL 管理"
    },
    {
      "name": "Redis",
      "description": "云 Redis 缓存管理"
    },
    {
      "name": "MongoDB",
      "description": "云 MongoDB 数据库管理"
    }
  ],
  "paths": {
    "/cam/databases/rds": {
      "get": {
        "tags": ["RDS"],
        "summary": "获取RDS实例列表",
        "description": "获取指定云账号和地域的RDS实例列表",
        "operationId": "listRDSInstances",
        "parameters": [
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "description": "云账号ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": true,
            "description": "地域",
            "schema": {
              "type": "string",
              "example": "cn-hangzhou"
            }
          },
          {
            "name": "engine",
            "in": "query",
            "required": false,
            "description": "数据库引擎",
            "schema": {
              "type": "string",
              "enum": ["mysql", "postgresql", "mariadb", "sqlserver"]
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "实例状态",
            "schema": {
              "type": "string",
              "enum": ["running", "stopped", "creating", "deleting"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RDSInstanceListResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "云账号不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cam/databases/rds/{instance_id}": {
      "get": {
        "tags": ["RDS"],
        "summary": "获取RDS实例详情",
        "description": "获取指定RDS实例的详细信息",
        "operationId": "getRDSInstance",
        "parameters": [
          {
            "name": "instance_id",
            "in": "path",
            "required": true,
            "description": "RDS实例ID",
            "schema": {
              "type": "string",
              "example": "rm-bp1xxxxx"
            }
          },
          {
            "name": "account_id",
            "in": "query",
            "required": true,
            "description": "云账号ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": true,
            "description": "地域",
            "schema": {
              "type": "string",
              "example": "cn-hangzhou"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RDSInstanceResponse"
                }
              }
            }
          },
          "404": {
            "description": "实例不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cam/databases/redis": {
      "get": {
        "tags": ["Redis"],
        "summary": "获取Redis实例列表",
        "description": "获取指定云账号和地域的Redis实例列表",
