{
  "openapi": "3.0.3",
  "info": {
    "title": "云资产管理 API",
    "description": "e-cam-service 云资产查询接口，支持 ECS、RDS、Redis、MongoDB、VPC、EIP 六种资产类型",
    "version": "2.2.0",
    "contact": {
      "name": "API Support",
      "email": "support@example.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080/api/v1",
      "description": "本地开发环境"
    },
    {
      "url": "https://api.example.com/api/v1",
      "description": "生产环境"
    }
  ],
  "tags": [
    {"name": "ECS", "description": "云虚拟机"},
    {"name": "RDS", "description": "关系型数据库"},
    {"name": "Redis", "description": "Redis缓存"},
    {"name": "MongoDB", "description": "MongoDB文档数据库"},
    {"name": "VPC", "description": "虚拟私有云"},
    {"name": "EIP", "description": "弹性公网IP"}
  ],
  "components": {
    "securitySchemes": {
      "TenantId": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Tenant-ID",
        "description": "租户ID，所有请求必须携带"
      }
    },
    "parameters": {
      "TenantIdHeader": {
        "name": "X-Tenant-ID",
        "in": "header",
        "required": true,
        "schema": {"type": "string"},
        "description": "租户ID",
        "example": "tenant-001"
      },
      "AccountId": {
        "name": "account_id",
        "in": "query",
        "schema": {"type": "integer"},
        "description": "云账号ID"
      },
      "Provider": {
        "name": "provider",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": ["aliyun", "aws", "huawei", "tencent", "volcano"]
        },
        "description": "云厂商"
      },
      "Region": {
        "name": "region",
        "in": "query",
        "schema": {"type": "string"},
        "description": "地域",
        "example": "cn-hangzhou"
      },
      "Status": {
        "name": "status",
        "in": "query",
        "schema": {"type": "string"},
        "description": "实例状态",
        "example": "running"
      },
      "Name": {
        "name": "name",
        "in": "query",
        "schema": {"type": "string"},
        "description": "实例名称（模糊搜索）"
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "schema": {"type": "integer", "default": 0},
        "description": "分页偏移量"
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": {"type": "integer", "default": 20},
        "description": "每页数量"
      }
    },
    "schemas": {
      "Asset": {
        "type": "object",
        "properties": {
          "id": {"type": "integer", "description": "数据库ID"},
          "asset_id": {"type": "string", "description": "云厂商实例ID"},
          "asset_name": {"type": "string", "description": "实例名称"},
          "asset_type": {
            "type": "string",
            "enum": ["ecs", "rds", "redis", "mongodb", "vpc", "eip"],
            "description": "资产类型"
          },
          "tenant_id": {"type": "string", "description": "租户ID"},
          "account_id": {"type": "integer", "description": "云账号ID"},
          "provider": {
            "type": "string",
            "enum": ["aliyun", "aws", "huawei", "tencent", "volcano"],
            "description": "云厂商"
          },
          "region": {"type": "string", "description": "地域"},
          "status": {"type": "string", "description": "实例状态"},
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "扩展属性"
          },
          "create_time": {"type": "integer", "description": "创建时间（毫秒时间戳）"},
          "update_time": {"type": "integer", "description": "更新时间（毫秒时间戳）"}
        }
      },
      "AssetListResponse": {
        "type": "object",
        "properties": {
          "code": {"type": "integer", "example": 0},
          "msg": {"type": "string", "example": "success"},
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {"$ref": "#/components/schemas/Asset"}
              },
              "total": {"type": "integer", "description": "总数"}
            }
          }
        }
      },
      "AssetDetailResponse": {
        "type": "object",
        "properties": {
          "code": {"type": "integer", "example": 0},
          "msg": {"type": "string", "example": "success"},
          "data": {"$ref": "#/components/schemas/Asset"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {"type": "integer"},
          "message": {"type": "string"}
        }
      }
    },
    "responses": {
      "TenantRequired": {
        "description": "租户ID不能为空",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"},
            "example": {"code": 400, "message": "租户ID不能为空"}
          }
        }
      },
      "NotFound": {
        "description": "资源不存在",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"},
            "example": {"code": 404, "msg": "实例不存在"}
          }
        }
      }
    }
  },
  "security": [{"TenantId": []}],
  "paths": {
    "/cam/assets/ecs": {
      "get": {
        "tags": ["ECS"],
        "summary": "获取ECS实例列表",
        "description": "从数据库获取已同步的云虚拟机实例列表",
        "operationId": "listECS",
        "parameters": [
          {"$ref": "#/components/parameters/TenantIdHeader"},
          {"$ref": "#/components/parameters/AccountId"},
          {"$ref": "#/components/parameters/Provider"},
          {"$ref": "#/components/parameters/Region"},
          {"$ref": "#/components/parameters/Status"},
          {"$ref": "#/components/parameters/Name"},
          {"$ref": "#/components/parameters/Offset"},
          {"$ref": "#/components/parameters/Limit"}
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/AssetListResponse"},
                "example": {
                  "code": 0,
                  "msg": "success",
                  "data": {
                    "items": [{
                      "id": 1,
                      "asset_id": "i-bp1xxxxx",
                      "asset_name": "web-server-01",
                      "asset_type": "ecs",
                      "tenant_id": "tenant-001",
                      "account_id": 1,
                      "provider": "aliyun",
                      "region": "cn-hangzhou",
                      "status": "running",
                      "attributes": {
                        "cpu": 4,
                        "memory": 8192,
                        "os_type": "linux",
                        "instance_type": "ecs.c6.xlarge"
                      },
                      "create_time": 1706000000000,
                      "update_time": 1706000000000
                    }],
                    "total": 100
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/TenantRequired"}
        }
      }
    },
    "/cam/assets/ecs/{asset_id}": {
      "get": {
        "tags": ["ECS"],
        "summary": "获取ECS实例详情",
        "operationId": "getECS",
        "parameters": [
          {"$ref": "#/components/parameters/TenantIdHeader"},
          {
            "name": "asset_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "云厂商实例ID"
          },
          {"$ref": "#/components/parameters/Provider"}
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/AssetDetailResponse"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/TenantRequired"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
